  phoneFrame: {fileID: 1565971886}
  npcMessages:
  - text: where are you.
    choices:
    - text: where else would i be
      score: 10
      actorLine: {fileID: 11400000, guid: 6126cdbc74e449446922cd1396cb34d4, type: 2}
    - text: work
      score: 10
      actorLine: {fileID: 11400000, guid: ae5cbea62e55e2345893685cd7361591, type: 2}
    - text: i dont like your tone
      score: 20
      actorLine: {fileID: 11400000, guid: 6126cdbc74e449446922cd1396cb34d4, type: 2}
    - text: work haha
      score: 10
      actorLine: {fileID: 11400000, guid: a736915d30a2b4442ae20699db131d04, type: 2}
  - text: When are you coming back home.
    choices:
    - text: i dont owe you answer
      score: 10
      actorLine: {fileID: 11400000, guid: 099d22b60d9d1654fad196acb366f3cf, type: 2}
    - text: why
      score: 1
      actorLine: {fileID: 11400000, guid: 7b0ba1f770886604880c02bbb7f04760, type: 2}
    - text: 20 like we said
      score: -10
      actorLine: {fileID: 11400000, guid: 58fd104cedb73b142b1dcee4dc9d280f, type: 2}
    - text: 20 is that ok
      score: -20
      actorLine: {fileID: 11400000, guid: f11862d5c4945c14781132b69c932dbe, type: 2}
    - text: late
      score: 10
      actorLine: {fileID: 11400000, guid: e5e5c9cd80c022344aa889765d2d9edc, type: 2}
    - text: dunno
      score: 5
      actorLine: {fileID: 11400000, guid: a736915d30a2b4442ae20699db131d04, type: 2}
  - text: Did you buy the groceries.
    choices:
    - text: shit no
      score: 20
      actorLine: {fileID: 11400000, guid: 6126cdbc74e449446922cd1396cb34d4, type: 2}
    - text: no
      score: 20
      actorLine: {fileID: 11400000, guid: e5e5c9cd80c022344aa889765d2d9edc, type: 2}
    - text: yes
      score: -10
      actorLine: {fileID: 11400000, guid: df8c3c5f5da2e23489e6d5771b0d29a0, type: 2}
    - text: of course
      score: -20
      actorLine: {fileID: 11400000, guid: 58fd104cedb73b142b1dcee4dc9d280f, type: 2}
    - text: didnt feel like it
      score: 20
      actorLine: {fileID: 11400000, guid: 099d22b60d9d1654fad196acb366f3cf, type: 2}
  - text: Are you staying late today.
    choices:
    - text: yes
      score: 20
      actorLine: {fileID: 11400000, guid: a736915d30a2b4442ae20699db131d04, type: 2}
    - text: no
      score: -10
      actorLine: {fileID: 11400000, guid: 58fd104cedb73b142b1dcee4dc9d280f, type: 2}
    - text: no i promise
      score: -20
      actorLine: {fileID: 11400000, guid: f11862d5c4945c14781132b69c932dbe, type: 2}
